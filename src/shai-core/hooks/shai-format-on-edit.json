{
    "$comment": "C-H01 — shai-format-on-edit | Runs Prettier after every file edit by the agent. See also: C-H02 (shai-lint-on-edit).",
    "hooks": {
        "PostToolUse": [
            {
                "type": "command",
                "command": "test -f \"$TOOL_INPUT_FILE_PATH\" && npx prettier --write \"$TOOL_INPUT_FILE_PATH\" && echo \"✔ Formatted: $TOOL_INPUT_FILE_PATH\"",
                "windows": "if (\"$TOOL_INPUT_FILE_PATH\") { npx prettier --write \"$TOOL_INPUT_FILE_PATH\"; Write-Host \"✔ Formatted: $TOOL_INPUT_FILE_PATH\" }",
                "timeout": 15
            }
        ]
    }
}