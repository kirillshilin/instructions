{
  "name": "@shai/instructions",
  "version": "0.1.0",
  "description": "Composable instruction sets for AI coding assistants",
  "license": "MIT",
  "bin": {
    "shai": "bin/install.js",
    "@shai/instructions": "bin/install.js"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "reference": "node scripts/build-reference.js",
    "check:budget": "node scripts/budget.js --all",
    "check:budget:instructions": "node scripts/budget.js --instructions",
    "check:instruction-size": "node scripts/budget.js --instructions"
  },
  "dependencies": {
    "yaml": "2.8.3"
  }
}